# ── Ghummakad environment ───────────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local.
# Generate the Supabase secrets with:  node scripts/gen-keys.mjs

# Public site URL (used as the same-origin Supabase URL via Caddy)
SITE_URL=http://168.144.24.204:8081

# Postgres / Supabase self-host (from scripts/gen-keys.mjs)
POSTGRES_PASSWORD=
JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Google AI Studio API key) — used server-side only
GEMINI_API_KEY=

# Google OAuth (optional — leave disabled until a real domain + redirect exist)
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
