# Ghummakad — plain HTTP on :80 inside the container (published as :8081 on the
# droplet). Serves Supabase-compatible /auth/v1 + /rest/v1 from the same origin
# as the app, so NEXT_PUBLIC_SUPABASE_URL is simply the site URL.
:80 {
	encode gzip

	handle_path /auth/v1/* {
		reverse_proxy auth:9999
	}

	handle_path /rest/v1/* {
		reverse_proxy rest:3000
	}

	handle {
		reverse_proxy web:3000
	}
}
